# ─────────────────────────── CORE ───────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# Database — para dev usamos SQLite, para prod Postgres
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/mesasmart"

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — dominios del frontend separados por coma
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,file://

# ─────────────────────────── INTEGRATIONS ───────────────────────────
# Si están vacíos, el sistema usa mocks que funcionan offline.

# OSE peruano (Nubefact)
MOCK_OSE=true
NUBEFACT_API_URL=
NUBEFACT_TOKEN=
SUNAT_BOLETA_SERIE=B001
SUNAT_FACTURA_SERIE=F001

# Pasarelas de pago
MOCK_PAYMENTS=true
CULQI_PUBLIC_KEY=
CULQI_PRIVATE_KEY=
NIUBIZ_MERCHANT_ID=
NIUBIZ_USERNAME=
NIUBIZ_PASSWORD=

# Yape Empresa / Plin (BCP) — requiere acuerdo comercial
YAPE_API_TOKEN=
PLIN_API_TOKEN=

# Email transaccional
MOCK_EMAIL=true
RESEND_API_KEY=
EMAIL_FROM=hola@mesasmart.pe

# WhatsApp Business
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# Storage (S3 / R2)
MOCK_STORAGE=true
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mesasmart

# ─────────────────────────── OBSERVABILITY ───────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# ─────────────────────────── AI (Anthropic Claude) ───────────────────────────
# Cómo usarlo:
# 1. Pega tu API key de Claude en ANTHROPIC_API_KEY abajo
# 2. Pon AI_FEATURES_ENABLED=true para activar features con AI
# Sin key, todos los endpoints siguen funcionando con fallback determinístico.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
AI_FEATURES_ENABLED=false
